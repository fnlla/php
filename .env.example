# ==============================================================================
# FNLLA PHP ENVIRONMENT TEMPLATE
# Copyright (c) 2026 TechAyo LTD (techayo.co.uk). All rights reserved.
# Produced, maintained and distributed by TechAyo LTD.
# This template defines the baseline local environment contract for FNLLA PHP.
# FNLLA PHP uses MySQL and the vendored FNLLA UI runtime in the official stack.
# ==============================================================================

APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_LOG_PATH=

FNLLA_UI_ENFORCE=true
FNLLA_UI_AUTO_SYNC=true
FNLLA_UI_SYNC_INTERVAL_SECONDS=900
FNLLA_UI_SYNC_SCRIPT=scripts/sync-fnlla-ui.ps1
FNLLA_UI_STATE_PATH=framework/fnlla-ui-guard.json

SESSION_NAME=fnlla_php_session
SESSION_LIFETIME_MINUTES=120
SESSION_ROTATE_AFTER_MINUTES=30
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_STRICT_MODE=true
SESSION_USE_ONLY_COOKIES=true

CSRF_ROTATE_AFTER_MINUTES=120

DB_DATABASE=fnlla
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_MIGRATIONS_TABLE=migrations

MAIL_MAILER=log
MAIL_LOG_PATH=mail
MAIL_FROM_ADDRESS=no-reply@example.com
CONTACT_NOTIFICATION_EMAIL=team@example.com

QUEUE_PATH=framework/queue

AUTH_SESSION_KEY=auth.user_id
AUTH_USERS_TABLE=users
AUTH_USERS_KEY=id
AUTH_USERS_IDENTITY=email
AUTH_USERS_PASSWORD=password
